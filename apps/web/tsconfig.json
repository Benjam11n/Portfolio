{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"],
      "@repo/analytics": ["../../packages/analytics/index.tsx"],
      "@repo/analytics/*": ["../../packages/analytics/*"]
    },
    "types": [
      "@react-three/fiber",
      "@testing-library/jest-dom",
      "vitest/globals"
    ],
    "strictNullChecks": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", "e2e/**/*"]
}
