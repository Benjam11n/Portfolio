# Resend Email Service
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email Configuration
# FROM_EMAIL: The verified sender email address (must be verified in Resend)
# TO_EMAIL: Your personal email where contact form submissions will be sent
# Note: These can be the same email address if you want to send from and receive at the same address
FROM_EMAIL=contact@yourdomain.com
TO_EMAIL=your.email@example.com

# Arcjet Security
# Get your key from: https://app.arcjet.com
ARCJET_KEY=ajkey_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Public app URL for generating absolute URLs, canonical links, etc.
# Uncomment and set this for production deployments
SITE_URL=https://yourdomain.com

# PostHog Analytics
# Get your keys from: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
